<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.wallbing.sync-wallpapers</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <!-- Edit REPO_ROOT if you cloned this repo somewhere else -->
    <string>REPO_ROOT="$HOME/projects/newbingapp"; [ -x "$REPO_ROOT/scripts/sync-wallpapers-from-pages.sh" ] &amp;&amp; "$REPO_ROOT/scripts/sync-wallpapers-from-pages.sh"</string>
  </array>
  <key>StartInterval</key>
  <integer>21600</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/wallbing-sync.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/wallbing-sync.err</string>
</dict>
</plist>
